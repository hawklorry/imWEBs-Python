import numpy as np
from whitebox import WhiteboxTools

def build_pour_points(stream_header, flow_dir_header, output_header, exception_areas=None):
    if exception_areas is None:
        exception_areas = []

    dX = [1, 1, 1, 0, -1, -1, -1, 0]
    dY = [-1, 0, 1, 1, 1, 0, -1, -1]
    inflowing_vals = [16, 32, 64, 128, 1, 2, 4, 8]

    wbt = WhiteboxTools()
    pntr = wbt.read_raster(flow_dir_header)
    streams = wbt.read_raster(stream_header)

    rows, cols = pntr.shape
    no_data = pntr.no_data_value
    has_exception = len(exception_areas) > 0
    exceptions = [wbt.read_raster(area) for area in exception_areas] if has_exception else []

    output = np.full((rows, cols), no_data, dtype=float)

    count = 0
    for row in range(rows):
        for col in range(cols):
            if streams[row, col] > 0:
                flow_dir = pntr[row, col]
                if flow_dir == 0:  # End of stream network
                    count += 1
                    output[row, col] = count
                    break

                # see if it is a headwater location
                num_neighbouring_stream_cells = 0
                for c in range(8):
                    x = col + dX[c]
                    y = row + dY[c]
                    if 0 <= y < rows and 0 <= x < cols and streams[y, x] > 0 and pntr[y, x] == inflowing_vals[c]:
                        num_neighbouring_stream_cells += 1

                if num_neighbouring_stream_cells > 1:
                    if has_exception:
                        flag = all(exception[row, col] <= 0 for exception in exceptions)
                        if not flag:
                            break

                    for c in range(8):
                        x = col + dX[c]
                        y = row + dY[c]
                        if 0 <= y < rows and 0 <= x < cols and streams[y, x] > 0 and pntr[y, x] == inflowing_vals[c]:
                            if has_exception:
                                flag = all(exception[y, x] <= 0 for exception in exceptions)
                                if not flag:
                                    break

                            count += 1
                            output[y, x] = count

    wbt.write_raster(output_header, output, pntr.cell_size, pntr.nodata_value, pntr.projection)

    # Convert raster to vector points
    wbt.raster_to_vector_points(output_header, output_header.replace(".dep", ".shp"))


